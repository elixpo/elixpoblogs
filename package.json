{
  "name": "elixpo-blogs",
  "type": "module",
  "dependencies": {
    "@blocknote/core": "^0.47.1",
    "@blocknote/mantine": "^0.47.1",
    "@blocknote/react": "^0.47.1",
    "@cloudflare/next-on-pages": "^1.13.0",
    "cropperjs": "^2.1.0",
    "next": "^15.3.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "6.0.2",
    "wrangler": "^4.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "npx @cloudflare/next-on-pages",
    "preview": "npx wrangler pages dev .vercel/output/static --compatibility-flags=nodejs_compat",
    "deploy": "npm run build && npx wrangler pages deploy .vercel/output/static",
    "db:migrate": "wrangler d1 execute elixpoblogs --remote --file=migrations/0001_init.sql"
  }
}
