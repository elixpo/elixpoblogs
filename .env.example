# Elixpo Accounts OAuth 2.0
# NEXT_PUBLIC_ = exposed to browser (safe for client ID)
# No prefix = server-only (required for secret)
NEXT_PUBLIC_ELIXPO_CLIENT_ID=your_client_id
ELIXPO_CLIENT_SECRET=your_client_secret

# Public URL (used for redirect_uri construction)
NEXT_PUBLIC_URL=https://localhost:3000

# Email (SMTP for local testing)
# For Gmail: generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM_EMAIL=you@gmail.com
SMTP_FROM_NAME=LixBlogs (noreply)

# Collaboration WebSocket URL (collab worker)
NEXT_PUBLIC_COLLAB_URL=wss://blog_collab.elixpo.com

# Cron secret — protects /api/cron/* endpoints from public access
# Call with: curl -H "Authorization: Bearer <secret>" https://blogs.elixpo.com/api/cron/weekly-digest
CRON_SECRET=your_cron_secret_here
